# Database
DB_HOST=127.0.0.1
DB_NAME=innonce_outfits
DB_USER=root
DB_PASS=

# Site URL (change for production)
SITE_URL=http://localhost:8080/innonce-outfits

# Clerk Authentication (https://clerk.com)
# Get your keys from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter AI (https://openrouter.ai)
# Get your key from https://openrouter.ai/keys
AI_FALLBACK_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
AI_FALLBACK_KEY=your-openrouter-api-key-here
# Model to use (default: openai/gpt-4o-mini)
AI_FALLBACK_MODEL=openai/gpt-4o-mini
